---
import Base from "../../layouts/Base.astro";
import { getKatas } from "../../lib/katas";

export async function getStaticPaths() {
  const katas = await getKatas();
  return katas.map((kata) => ({ params: { slug: kata.slug }, props: { kata } }));
}

const { kata } = Astro.props;
const base = import.meta.env.BASE_URL;
const repoUrl = "https://github.com/otmanecherradi/code-katas";
---

<Base title={`${kata.name} · Code Katas`}>
  <header class="sticky top-0 z-20 border-b border-zinc-800 bg-zinc-950/90 backdrop-blur">
    <div class="mx-auto max-w-6xl px-5 py-5">
      <div class="flex items-center justify-between gap-3 text-sm">
        <a href={base} class="text-zinc-400 hover:text-zinc-200">← All katas</a>
        <a
          href={kata.url}
          target="_blank"
          rel="noopener"
          class="text-zinc-400 hover:text-zinc-200"
        >
          View on Codewars ↗
        </a>
      </div>
      <p class="mt-3 text-xs font-medium uppercase tracking-widest text-blue-400">
        {kata.kyu} · {kata.category}
      </p>
      <h1 class="mt-1 text-2xl font-bold sm:text-3xl">{kata.name}</h1>
      {
        kata.tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-1.5">
            {kata.tags.map((t) => (
              <span class="rounded-full border border-zinc-700 px-2 py-0.5 text-xs text-zinc-400">
                {t}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </header>

  <main class="mx-auto max-w-6xl px-5 py-8">
    <div class="grid gap-8 lg:grid-cols-2 lg:items-start">
      <article
        class="prose prose-sm prose-invert max-w-none rounded-lg border border-zinc-800 bg-zinc-900 px-5 py-1"
        set:html={kata.descriptionHtml}
      />

      <section>
        <h2 class="mb-3 text-sm font-medium text-zinc-400">Solutions</h2>
        {
          kata.solutions.length === 0 ? (
            <p class="text-zinc-500">Not solved yet.</p>
          ) : (
            <div class="tabs">
              {kata.solutions.length > 1 && (
                <div role="tablist" class="flex flex-wrap gap-1 border-b border-zinc-800">
                  {kata.solutions.map((s, i) => (
                    <button
                      type="button"
                      class="tab -mb-px border-b-2 border-transparent px-3 py-1.5 text-sm text-zinc-400 hover:text-zinc-200 aria-selected:border-blue-400 aria-selected:text-blue-300"
                      data-tab={s.lang}
                      aria-selected={i === 0 ? "true" : "false"}
                    >
                      {s.lang}
                    </button>
                  ))}
                </div>
              )}
              {kata.solutions.map((s, i) => (
                <div class="panel mt-3" data-panel={s.lang} hidden={i !== 0}>
                  <div class="flex items-center justify-between rounded-t-lg border border-zinc-800 bg-zinc-900 px-3 py-1.5 text-xs">
                    <span class="text-zinc-500">{s.path.split("/").pop()}</span>
                    <a
                      href={`${repoUrl}/blob/main/${s.path}`}
                      target="_blank"
                      rel="noopener"
                      class="text-zinc-400 hover:text-zinc-200"
                    >
                      View on GitHub ↗
                    </a>
                  </div>
                  <div
                    class="overflow-x-auto rounded-b-lg border border-t-0 border-zinc-800 text-sm [&>pre]:p-4"
                    set:html={s.html}
                  />
                </div>
              ))}
            </div>
          )
        }
      </section>
    </div>
  </main>

  <script>
    for (const tabs of document.querySelectorAll<HTMLElement>(".tabs")) {
      const buttons = [...tabs.querySelectorAll<HTMLButtonElement>(".tab")];
      const panels = [...tabs.querySelectorAll<HTMLElement>(".panel")];
      for (const btn of buttons) {
        btn.addEventListener("click", () => {
          for (const b of buttons)
            b.setAttribute("aria-selected", String(b === btn));
          for (const p of panels) p.hidden = p.dataset.panel !== btn.dataset.tab;
        });
      }
    }
  </script>
</Base>
