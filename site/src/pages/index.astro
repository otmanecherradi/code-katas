---
import Base from "../layouts/Base.astro";
import { getKatas } from "../lib/katas";

const katas = await getKatas();
const base = import.meta.env.BASE_URL;

const ranks = [...new Set(katas.map((k) => k.rank))].sort((a, b) => b - a);
const languages = [
  ...new Set(katas.flatMap((k) => k.solutions.map((s) => s.lang))),
].sort();

const totalSolutions = katas.reduce((n, k) => n + k.solutions.length, 0);
const codewarsUrl = "https://www.codewars.com/users/otmanecherradi";
const repoUrl = "https://github.com/otmanecherradi/code-katas";
---

<Base title="Code Katas">
  <header class="border-b border-zinc-800">
    <div class="mx-auto max-w-4xl px-5 py-10">
      <p class="text-xs font-medium uppercase tracking-widest text-blue-400">Codewars</p>
      <h1 class="mt-1 text-3xl font-bold">Code Katas</h1>
      <p class="mt-2 max-w-prose text-zinc-400">
        A running log of the katas I've solved on Codewars — hopefully one every day.
      </p>
      <div class="mt-5 flex flex-wrap gap-2 text-xs">
        <span class="rounded-full border border-zinc-800 bg-zinc-900 px-3 py-1 text-zinc-300">
          {katas.length} katas
        </span>
        <span class="rounded-full border border-zinc-800 bg-zinc-900 px-3 py-1 text-zinc-300">
          {totalSolutions} solutions
        </span>
        <span class="rounded-full border border-zinc-800 bg-zinc-900 px-3 py-1 text-zinc-300">
          {languages.length} languages
        </span>
        <a
          href={codewarsUrl}
          target="_blank"
          rel="noopener"
          class="rounded-full border border-blue-500/30 bg-blue-500/10 px-3 py-1 text-blue-300 hover:bg-blue-500/20"
        >
          My Codewars profile ↗
        </a>
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener"
          class="rounded-full border border-zinc-700 px-3 py-1 text-zinc-300 hover:border-zinc-500"
        >
          GitHub ↗
        </a>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-4xl px-5 pb-16">
    <div class="my-6 flex flex-wrap gap-3">
      <input
        id="search"
        type="search"
        placeholder="Search katas or tags…"
        class="min-w-44 flex-1 rounded-lg border border-zinc-800 bg-zinc-900 px-3 py-2 text-sm placeholder:text-zinc-500 focus:border-blue-500 focus:outline-none"
      />
      <select
        id="kyu"
        class="rounded-lg border border-zinc-800 bg-zinc-900 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none"
      >
        <option value="">All kyu</option>
        {ranks.map((r) => <option value={r}>{r} kyu</option>)}
      </select>
      <select
        id="lang"
        class="rounded-lg border border-zinc-800 bg-zinc-900 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none"
      >
        <option value="">All languages</option>
        {languages.map((l) => <option value={l}>{l}</option>)}
      </select>
    </div>

    <p id="empty" class="hidden py-8 text-center text-zinc-500">No katas match.</p>

    {
      ranks.map((rank) => (
        <section class="kyu-group mt-8" data-kyu={rank}>
          <h2 class="border-b border-zinc-800 pb-2 text-sm font-medium text-zinc-400">
            {rank} kyu
          </h2>
          <div class="mt-3 grid gap-3 sm:grid-cols-2">
            {katas
              .filter((k) => k.rank === rank)
              .sort((a, b) => a.name.localeCompare(b.name))
              .map((k) => (
                <a
                  href={`${base}kata/${k.slug}/`}
                  class="card flex flex-col gap-2 rounded-lg border border-zinc-800 bg-zinc-900 p-4 transition-colors hover:border-zinc-600 hover:no-underline"
                  data-name={`${k.name} ${k.tags.join(" ")}`.toLowerCase()}
                  data-kyu={k.rank}
                  data-langs={k.solutions.map((s) => s.lang).join(" ")}
                >
                  <h3 class="font-medium text-zinc-100">{k.name}</h3>
                  <div class="mt-auto flex flex-wrap gap-1.5">
                    {k.solutions.length === 0 && (
                      <span class="rounded-full border border-dashed border-zinc-700 px-2 py-0.5 text-xs text-zinc-500">
                        unsolved
                      </span>
                    )}
                    {k.solutions.map((s) => (
                      <span class="rounded-full bg-blue-500/10 px-2 py-0.5 text-xs text-blue-300">
                        {s.lang}
                      </span>
                    ))}
                  </div>
                </a>
              ))}
          </div>
        </section>
      ))
    }
  </main>

  <script>
    const search = document.getElementById("search") as HTMLInputElement;
    const kyu = document.getElementById("kyu") as HTMLSelectElement;
    const lang = document.getElementById("lang") as HTMLSelectElement;
    const empty = document.getElementById("empty")!;
    const cards = [...document.querySelectorAll<HTMLElement>(".card")];
    const groups = [...document.querySelectorAll<HTMLElement>(".kyu-group")];

    function apply() {
      const q = search.value.trim().toLowerCase();
      const k = kyu.value;
      const l = lang.value;
      let visible = 0;

      for (const card of cards) {
        const matches =
          (!q || card.dataset.name!.includes(q)) &&
          (!k || card.dataset.kyu === k) &&
          (!l || card.dataset.langs!.split(" ").includes(l));
        card.classList.toggle("hidden", !matches);
        if (matches) visible++;
      }

      for (const group of groups) {
        const anyVisible = group.querySelector(".card:not(.hidden)");
        group.classList.toggle("hidden", !anyVisible);
      }
      empty.classList.toggle("hidden", visible > 0);
    }

    for (const el of [search, kyu, lang]) el.addEventListener("input", apply);
  </script>
</Base>
